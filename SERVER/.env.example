# =============================================================================
# SERVER ENVIRONMENT — template. Copy to `.env` and fill in real values.
# =============================================================================

# PostgreSQL connection string (REQUIRED)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Secret for signing JWT access tokens (REQUIRED)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=""

# Server
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="debug"

# Comma-separated allowed frontend origins (Vite dev defaults to 5173)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
